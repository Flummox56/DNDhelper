# Environment
ASPNETCORE_ENVIRONMENT=Development

# JWT Settings
JWT_KEY=your-super-secret-key-with-at-least-32-characters-for-jwt!
JWT_ISSUER=DNDhelper
JWT_AUDIENCE=DNDhelperClient

# Gateway Database
GATEWAY_DB_NAME=auth_db
GATEWAY_DB_USER=auth_user
GATEWAY_DB_PASSWORD=auth_password

# Sheet Database
SHEET_DB_NAME=monster_db
SHEET_DB_USER=sheet_user
SHEET_DB_PASSWORD=sheet_password